FROM node:22-bookworm-slim

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci
RUN npm install -g opencode-linux-arm64@1.17.11 opencode-ai@1.17.11

COPY apps ./apps
COPY packages ./packages
COPY scripts ./scripts
COPY config ./config
COPY agents ./agents
COPY data ./data
COPY tsconfig.base.json ./tsconfig.base.json

RUN npm run build:web

ENV NODE_ENV=development
ENV API_HOST=0.0.0.0
ENV API_PORT=3001
ENV AGENT_RUNNER=mock
ENV WORKSPACES_DIR=/app/workspaces
ENV TASK_STORE_FILE=/app/data/tasks.json

EXPOSE 3001

CMD ["npm", "run", "dev:api"]
